{
  "name": "@ninemind/agentgem",
  "version": "0.3.1",
  "description": "A local web UI that introspects your coding-agent config, redacts secrets at capture, and builds a portable, composable Gem.",
  "license": "MIT",
  "bin": {
    "agentgem": "dist/cli.js",
    "agentgem-distill": "dist/distill/mcpServer.js"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "ninemind.ai",
  "homepage": "https://agentgem.ninemind.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentgem.git"
  },
  "bugs": {
    "url": "https://github.com/ninemindai/agentgem/issues"
  },
  "keywords": [
    "claude",
    "coding-agent",
    "mcp",
    "agentback",
    "secret-redaction",
    "agent-config",
    "gem"
  ],
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "tsc -b && node scripts/copy-public.mjs",
    "dev": "pnpm build && node dist/index.js",
    "start": "node dist/index.js",
    "build:site": "node website/build.mjs",
    "test": "tsc -b && vitest run",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@agentback/core": "^0.5.2",
    "@agentback/drizzle": "~0.5.2",
    "@agentback/mcp": "^0.5.2",
    "@agentback/mcp-http": "^0.5.2",
    "@agentback/openapi": "^0.5.2",
    "@agentback/rest": "^0.5.2",
    "@agentback/rest-explorer": "^0.5.2",
    "@agentclientprotocol/sdk": "^0.28.1",
    "@anthropic-ai/sdk": "^0.104.2",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1073.0",
    "@electric-sql/pglite": "^0.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nats-io/jwt": "0.0.10-5",
    "@nats-io/nats-core": "^3.4.0",
    "@nats-io/nkeys": "^2.0.3",
    "@nats-io/obj": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.22.0",
    "tslib": "^2.8.1",
    "undici": "^6.27.0",
    "vercel": "^54.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6",
    "eve": "^0.15.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "supertest": "^7",
    "typescript": "^6",
    "vitest": "^3"
  }
}
